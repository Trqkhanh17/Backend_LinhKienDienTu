# Server
HOST_NAME=localhost
PORT=8000

# Database
# Use this URL when running the API directly on your machine.
DATABASE_URL="your-db-url"

# Use this URL inside Docker Compose if you do not override it there.
# DATABASE_URL="mysql://root_user:123456@mysql:3306/DBLinhKienDienTu"

# Auth
JWT_KEY="replace-with-a-long-random-secret"

# Mail
EMAIL="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"

# Firebase
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
